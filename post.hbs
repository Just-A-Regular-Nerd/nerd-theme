{{!< default}}

<div class="full">
	{{#post}}
			<h1>{{title}}</h1>
			<figure class="kg-card kg-image-card kg-card-hascaption">
				<img class="kg-image" src={{feature_image}} alt={{feature_image_alt}}>
				{{#if feature_image_caption}}
					<figcaption>
						<span style="white-space: pre-wrap;">{{feature_image_caption}}</span>
					</figcaption>
				{{/if}}
			</figure>
			<h3>Published <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="D MMM YYYY"}}</time></h3>
			<p>{{content}}</p>
	{{/post}}
	
	<nav class="post-navigation">
		{{#prev_post}}
			<a href="{{url}}" class="prev-post">Prev: {{title}}</a>
		{{/prev_post}}
		
		{{#next_post}}
			<a href="{{url}}" class="next-post">Next: {{title}}</a>
		{{/next_post}}
	</nav>
</div>