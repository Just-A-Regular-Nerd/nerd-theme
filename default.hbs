<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    <meta charset="utf-8" />
    <title>{{meta_title}}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" type="text/css" href="{{asset "css/style.css"}}" />
    {{ghost_head}} {{! Outputs SEO meta tags and scripts }}
</head>
<body class="{{body_class}}">
	<div class="container">
		<header>
			<span>{{@site.title}}</span>
		</header>

		{{{body}}}

    <footer>
        <span>&copy; {{date format="YYYY"}} {{@site.title}} | <a href="{{@site.url}}/rss/">RSS Feed</a> | cyanobacteria.css by <a href="https://ribo.zone/free/layouts/">ribo.zone</a></span>
    </footer>

    {{ghost_foot}} {{! Outputs required scripts }}
</body>
</html>
