{{!< default}}

<div class="archive">
  <h1>All Posts</h1>
  
  {{#foreach posts limit="all"}}
    <article class="post-archive-item">
      <h2><a href="{{url}}">{{title}}</a></h2>
      <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="D MMM YYYY"}}</time>
      <p>{{excerpt}}</p>
    </article>
  {{/foreach}}
</div>
