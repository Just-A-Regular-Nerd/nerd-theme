{{!< default}}

<div class="small">
	<!-- site map -->
	{{> "navigation"}}
	<!-- featured post -->
	{{#get "posts" filter="featured:true" limit="all"}}
		<nav>
			<h3>Featured posts</h3>
			{{#if posts}}
				{{#foreach posts}}
					<p>{{title}}</p>
					{{#if feature_image}}
						<a href="{{url}}">
							<img class="kg-image" src={{img_url feature_image size="thumbnail" format="webp"}} alt={{feature_image_alt}}>
						</a>
					{{/if}}
					<p>{{excerpt}}</p>
					<a href="{{url}}">Read more...</a>
				{{/foreach}}
			{{else}}
				<p>There are no featured posts at the moment.</p>
			{{/if}}
		</nav>
	{{/get}}
	<!-- post list -->
	<nav>
		<div>all posts</div>
		  {{#foreach posts limit="all"}}
			<article class="post-archive-item">
			  <a href="{{url}}">{{title}}</a>
			  <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="D MMM YYYY"}}</time>
			  <p>{{excerpt}}</p>
			</article>
		  {{/foreach}}
	</nav>
</div>

<section class="half">
	<article class="about-post" id="about-post"></article>
</section>

<script>
  function renderAboutPost() {
    if (window.aboutPageData) {
      const page = window.aboutPageData;
      const aboutEl = document.getElementById('about-post');
      const dateStr = new Date(page.updated_at).toLocaleDateString('en-US', { 
        year: 'numeric', 
        month: 'short', 
        day: 'numeric' 
      });
      
      aboutEl.innerHTML = `
        <h3>Last updated <time datetime="${page.published_at}">${dateStr}</time></h3>
        <div class="post-content">${page.html}</div>
      `;
    }
  }
  
  // Wait for the about page data to load, then render
  if (window.aboutPageData) {
    renderAboutPost();
  } else {
    // If not loaded yet, wait a bit and try again
    setTimeout(renderAboutPost, 750);
  }
</script>
