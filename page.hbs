{{!< default}}

{{#post}}
<article class="{{post_class}}">
    
    {{#match @page.show_title_and_feature_image}}
        <header class="post-header">
            <h1 class="post-title">{{title}}</h1>
            {{#if feature_image}}
                <img src="{{feature_image}}" alt="{{title}}" />
            {{/if}}
        </header>
    {{/match}}

    <section class="gh-content">
        {{content}}
    </section>

</article>
{{/post}}
